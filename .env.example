# ─────────────────────────────────────────────────────────────────────
# AceForge v0.9.0 — Environment Configuration
# https://github.com/sudokrang/aceforge
# ─────────────────────────────────────────────────────────────────────
# All variables are optional. AceForge reads defaults from openclaw.json
# when provider-specific overrides are not set.
#
# Both generator and reviewer accept any OpenAI-compatible endpoint.
# ─────────────────────────────────────────────────────────────────────

# ── Generator (writes SKILL.md from trace data) ─────────────────────
# ACEFORGE_GENERATOR_PROVIDER=minimax
# ACEFORGE_GENERATOR_API_KEY=
# ACEFORGE_GENERATOR_MODEL=MiniMax-M2.7
# ACEFORGE_GENERATOR_URL=https://api.minimax.io/v1

# ── Reviewer (critiques generated skills with CoT) ──────────────────
# ACEFORGE_REVIEWER_PROVIDER=deepseek
# ACEFORGE_REVIEWER_API_KEY=
# ACEFORGE_REVIEWER_MODEL=deepseek-chat
# ACEFORGE_REVIEWER_URL=https://api.deepseek.com

# ── Notifications ────────────────────────────────────────────────────
# Auto-detects from openclaw.json. Override to force a channel.
# ACEFORGE_NOTIFICATION_CHANNEL=telegram   # telegram | slack | log
# ACEFORGE_TELEGRAM_BOT_TOKEN=
# ACEFORGE_OWNER_CHAT_ID=
# ACEFORGE_SLACK_WEBHOOK_URL=

# ── Notification Digest (optional — batch notifications) ─────────────
# ACEFORGE_NOTIFY_DIGEST=true   # Queue notifications, flush as single message per cycle

# ── OpenViking (optional — context-enriched challenges) ──────────────
# ACEFORGE_VIKING_URL=http://127.0.0.1:1933

# ── Doc Enrichment (optional — secondary doc source) ─────────────
# ACEFORGE_DOCS_URL=https://docs.openclaw.ai
